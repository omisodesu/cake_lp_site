---
import { testimonials } from '../../data/testimonials';
import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>('../../images/shop*.jpg', { eager: true });
---
<section class="section testimonials" id="testimonials">
  <div class="container">
    <h2>導入店舗からの声</h2>
    <ul class="testimonials__grid">
      {testimonials.map((testimonial) => {
        const imagePath = `../../images/${testimonial.image}`;
        const imageModule = images[imagePath];
        return (
          <li class="testimonial-card">
            <article>
              {imageModule && (
                <Image src={imageModule.default} alt={testimonial.alt} class="testimonial-card__image" width={600} />
              )}
              <blockquote class="testimonial-card__text">
                <p>{testimonial.text}</p>
              </blockquote>
              <p class="testimonial-card__author"><cite>{testimonial.author}</cite></p>
              {testimonial.improvement && (
                <p class="testimonial-card__improvement">
                  <strong>導入効果:</strong> {testimonial.improvement}
                </p>
              )}
              <a href={testimonial.link} class="testimonial-card__link" data-case-name={testimonial.id}>導入事例を詳しく見る →</a>
            </article>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--white);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    margin-top: 40px;
    list-style: none;
    padding: 0;
  }

  .testimonial-card {
    background-color: var(--white);
    border-radius: var(--border-radius);
    padding: 30px;
    box-shadow: var(--shadow);
  }

  .testimonial-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--border-radius);
    margin-bottom: 20px;
  }

  .testimonial-card__text {
    font-style: italic;
    margin: 0 0 20px;
    position: relative;
  }

  .testimonial-card__text:before,
  .testimonial-card__text:after {
    content: '"';
    font-size: 1.5rem;
    color: var(--accent-color);
  }

  .testimonial-card__author {
    font-weight: bold;
    text-align: right;
  }

  .testimonial-card__link {
    display: inline-block;
    margin-top: 15px;
    color: var(--accent-color);
    text-decoration: none;
    font-weight: bold;
    transition: opacity 0.3s ease;
  }

  .testimonial-card__improvement {
    background-color: var(--secondary-color);
    padding: 12px 16px;
    border-radius: var(--border-radius);
    border-left: 4px solid var(--accent-color);
    margin-top: 16px;
    font-style: normal;
  }

  .testimonial-card__link:hover {
    opacity: 0.7;
  }
</style>
