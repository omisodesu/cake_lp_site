---
import { faqItems } from '../../data/faq';

// 表示するFAQ項目を差し替えられるようにする軽微な汎用化（/christmas/ でのFAQ抜粋再掲用）。
// items 未指定なら全件表示＝TOPページの従来挙動のまま。文言は faq.ts で一元管理する。
interface Props {
  items?: ReadonlyArray<(typeof faqItems)[number]>;
}

const { items = faqItems } = Astro.props;
---
<section class="section faq" id="faq">
  <div class="container">
    <h2>よくある質問</h2>
    <div class="faq__list">
      {items.map((item) => (
        <details class="faq__item" data-faq-id={item.id}>
          <summary class="faq__question">
            {item.question}
          </summary>
          <div class="faq__answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDetailsElement>('.faq__item').forEach(details => {
    details.addEventListener('toggle', () => {
      if (details.open && typeof gtag === 'function') {
        gtag('event', 'faq_open', {
          question: details.dataset.faqId || '',
        });
      }
    });
  });

  declare function gtag(...args: any[]): void;
</script>

<style>
  .faq {
    background-color: var(--white);
  }

  .faq__list {
    max-width: 800px;
    margin: 40px auto 0;
  }

  .faq__item {
    margin-bottom: 20px;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .faq__question {
    display: block;
    width: 100%;
    background-color: var(--secondary-color);
    padding: 20px;
    cursor: pointer;
    position: relative;
    font-weight: bold;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::after {
    content: '+';
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    transition: transform 0.3s ease;
  }

  .faq__item[open] .faq__question::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .faq__answer {
    background-color: var(--white);
    padding: 20px;
  }
</style>
