---
// 注意: 現在どのページからも使用されていないコンポーネント（index.astro は ResultsSummary を使用）
// results データの形式変更（タスク3-2）に合わせて同期済み。
// 値が「0→152」など数値型でなくなったため、カウントアップアニメーションは廃止した
import { results } from '../../data/results';
---
<section class="section results" id="results">
  <div class="container">
    <h2>導入店舗の実績が証明する効果</h2>
    <dl class="results__grid">
      {results.map((result) => (
        <div class="result-card">
          <dt class="result-card__title">{result.title}</dt>
          <dd class="result-card__value">
            <span class="result-card__number">{result.value}<span class="result-card__unit">{result.unit}</span></span>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .results {
    background-color: var(--white);
  }

  .results__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-top: 40px;
    padding: 0;
  }

  .result-card {
    display: flex;
    flex-direction: column;
    background-color: var(--secondary-color);
    border-radius: var(--border-radius);
    padding: 30px;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .result-card__value {
    order: -1;
    margin: 0;
  }

  .result-card__number {
    font-size: 3rem;
    font-weight: bold;
    color: var(--accent-color);
    margin-bottom: 10px;
    display: block;
  }

  .result-card__unit {
    font-size: 1.4rem;
  }

  .result-card__title {
    font-size: 1.3rem;
    margin-bottom: 15px;
    font-weight: bold;
  }
</style>
