---
import Icon from '../common/Icon.astro';

const signals = [
  {
    icon: 'clock',
    title: '1営業日以内に返信',
    description: 'お問い合わせいただいてから1営業日以内にご連絡いたします。',
  },
  {
    icon: 'file-alt',
    title: '資料請求だけでもOK',
    description: 'まずは資料だけ見たいという方も大歓迎です。',
  },
  {
    icon: 'hand-peace',
    title: 'しつこい営業は一切なし',
    description: 'お客様のペースを大切にします。無理な勧誘は一切いたしません。',
  },
];
---
<section class="section trust-signals" aria-label="お問い合わせに関する安心材料">
  <div class="container">
    <h2>安心してお問い合わせください</h2>
    <ul class="trust-signals__list">
      {signals.map((signal) => (
        <li class="trust-signal">
          <div class="trust-signal__icon" aria-hidden="true">
            <Icon name={signal.icon} />
          </div>
          <h3 class="trust-signal__title">{signal.title}</h3>
          <p>{signal.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-signals {
    background-color: var(--secondary-color);
  }

  .trust-signals__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-top: 40px;
    list-style: none;
    padding: 0;
  }

  .trust-signal {
    background-color: var(--white);
    border-radius: var(--border-radius);
    padding: 30px;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .trust-signal__icon {
    font-size: 2.5rem;
    color: var(--accent-color);
    margin-bottom: 15px;
  }

  .trust-signal__title {
    font-size: 1.3rem;
    margin-bottom: 10px;
  }
</style>
