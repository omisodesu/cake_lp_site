---
// クリスマス前倒し訴求の告知バー（修正指示書 第4弾 タスク3で再点灯）。
// 掲載を止める際は isAnnouncementVisible を false に戻す（本文・計測コードは温存して再利用する）。
// 閉じるボタンの計測（announcement_bar_close / ga4-events.ts）と
// リンクの cta_click 計測（data-cta-location="announcement"）は ga4-events.ts が自動で拾う。
// モバイル（480px以下）では1行に収まらないため、CSSで短縮版の文言に出し分ける（コピーは指示書の許容範囲内）。
const isAnnouncementVisible = true;
---
{isAnnouncementVisible && (
  <div class="announcement-bar" id="announcement-bar" aria-label="クリスマス予約準備のお知らせ">
    <div class="announcement-bar__inner">
      <p class="announcement-bar__text">
        <span class="announcement-bar__text-full">クリスマスケーキのWEB予約、受付の準備はお早めに。<a href="/christmas/" class="announcement-bar__link" data-cta-location="announcement" data-cta-type="christmas_page">→ 詳しく見る</a></span>
        <span class="announcement-bar__text-short"><a href="/christmas/" class="announcement-bar__link" data-cta-location="announcement" data-cta-type="christmas_page">クリスマスのWEB予約、準備はお早めに →</a></span>
      </p>
      <button
        class="announcement-bar__close"
        type="button"
        aria-label="お知らせバーを閉じる"
        data-announcement-close
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>
)}

<script>
  const bar = document.getElementById('announcement-bar');
  if (bar) {
    if (sessionStorage.getItem('announcement-bar-closed') === '1') {
      bar.hidden = true;
    }
    const closeBtn = bar.querySelector('[data-announcement-close]');
    closeBtn?.addEventListener('click', () => {
      bar.hidden = true;
      sessionStorage.setItem('announcement-bar-closed', '1');
    });
  }
</script>

<style>
  .announcement-bar {
    background-color: #8B4513;
    color: var(--white);
    font-size: 0.875rem;
    line-height: 1.5;
    position: relative;
    z-index: 1100;
  }

  .announcement-bar[hidden] {
    display: none;
  }

  .announcement-bar__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 48px 8px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .announcement-bar__text {
    margin: 0;
    text-align: center;
    color: var(--white);
  }

  /* 480px以下は短縮版の文言に出し分け（1行維持のため） */
  .announcement-bar__text-short {
    display: none;
  }

  @media (max-width: 480px) {
    .announcement-bar__text-full {
      display: none;
    }

    .announcement-bar__text-short {
      display: inline;
    }
  }

  .announcement-bar__link {
    color: var(--white);
    text-decoration: underline;
    font-weight: bold;
  }

  .announcement-bar__link:hover {
    color: #FFE4C4;
  }

  .announcement-bar__close {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--white);
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .announcement-bar__close:hover {
    background-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .announcement-bar__inner {
      padding: 8px 40px 8px 16px;
    }

    .announcement-bar__text {
      font-size: 0.8rem;
    }
  }
</style>
