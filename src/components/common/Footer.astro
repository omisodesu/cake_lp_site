---
import { COMPANY } from '../../data/site';
---
<footer class="footer">
  <div class="container">
    <div class="footer__content">
      <div class="footer__column">
        <h3 class="footer__title">いつでもケーキ</h3>
        <p>{COMPANY.name}</p>
        <p>代表取締役 {COMPANY.representative}</p>
        <p>{COMPANY.postalCode}<br />{COMPANY.address}</p>
        <p>mail: {COMPANY.email}</p>
      </div>
      <div class="footer__column">
        <h3 class="footer__title">サービス</h3>
        <ul class="footer__links">
          <li class="footer__link"><a href="/#service">サービス概要</a></li>
          <li class="footer__link"><a href="/#features">機能紹介</a></li>
          <li class="footer__link"><a href="/#pricing">料金プラン</a></li>
          <li class="footer__link"><a href="/#process">導入の流れ</a></li>
        </ul>
      </div>
      <div class="footer__column">
        <h3 class="footer__title">会社情報</h3>
        <ul class="footer__links">
          <li class="footer__link"><a href={COMPANY.corporateUrl} target="_blank">会社概要</a></li>
          <li class="footer__link"><a href="/legal/privacy-policy/">プライバシーポリシー</a></li>
          <li class="footer__link"><a href="/legal/terms-of-service/">利用規約</a></li>
          <li class="footer__link"><a href="/legal/tokusho/">特定商取引法に基づく表記</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; 2025 いつでもケーキ All Rights Reserved.</p>
    </div>
  </div>
</footer>
