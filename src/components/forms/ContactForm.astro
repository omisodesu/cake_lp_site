---
import '../../styles/form.css';
import { SITE } from '../../data/site';

interface Props {
  showPersonInCharge?: boolean;
}

const { showPersonInCharge = true } = Astro.props;
---
<form id="contact-form" class="contact-form" data-function-url={SITE.cloudFunctionUrl}>
  <div class="form-group">
    <label for="shop-name">店舗名・会社名※個人の方はなしご記入ください <span class="required">*</span></label>
    <input type="text" id="shop-name" name="shop-name" required>
  </div>

  {showPersonInCharge && (
    <div class="form-group">
      <label for="person-in-charge">担当者名</label>
      <input type="text" id="person-in-charge" name="person-in-charge">
    </div>
  )}

  <div class="form-group">
    <label for="name">お名前 <span class="required">*</span></label>
    <input type="text" id="name" name="name" required>
  </div>
  <div class="form-group">
    <label for="email">メールアドレス <span class="required">*</span></label>
    <input type="email" id="email" name="email" required>
  </div>
  <div class="form-group">
    <label for="phone">電話番号</label>
    <input type="tel" id="phone" name="phone">
  </div>

  <div class="form-group">
    <label for="lead-source">どこで当サービスを知りましたか？</label>
    <select id="lead-source" name="lead_source">
      <option value="">選択してください</option>
      <option value="google_search">Google検索</option>
      <option value="sns">SNS</option>
      <option value="referral">知人の紹介</option>
      <option value="trade_show">展示会</option>
      <option value="other">その他</option>
    </select>
  </div>

  <div class="form-group hidden" id="lead-source-other-group">
    <label for="lead-source-other-details">流入元（その他）</label>
    <textarea id="lead-source-other-details" name="lead_source_other_details" rows="2" maxlength="200" placeholder="具体的にご記入ください（200文字以内）"></textarea>
    <p id="lead-source-char-count" class="char-count">0 / 200</p>
  </div>

  <div class="form-group">
    <label for="inquiry-type">お問い合わせ <span class="required">*</span></label>
    <select id="inquiry-type" name="inquiry_type" required>
      <option value="">選択してください</option>
      <option value="request_documents">資料請求</option>
      <option value="request_contact">商品の説明が聞きたいので連絡が欲しい</option>
      <option value="other">その他</option>
    </select>
  </div>

  <div class="form-group hidden" id="other-inquiry-details-group">
    <label for="other-inquiry-details">お問い合わせ内容（その他）<span class="required">*</span></label>
    <textarea id="other-inquiry-details" name="other_inquiry_details" rows="4" maxlength="200" placeholder="具体的な内容を200文字以内でご記入ください"></textarea>
    <p id="char-count" class="char-count">0 / 200</p>
  </div>

  <div style="position: absolute; left: -9999px;" aria-hidden="true">
    <label for="website-url-hp">Website URL</label>
    <input type="text" id="website-url-hp" name="website_url" tabindex="-1" autocomplete="off">
  </div>

  <div class="form-group">
    <div class="cf-turnstile" data-sitekey={SITE.turnstileSiteKey} data-refresh-expired="auto" data-callback="__onTurnstileSuccess" data-expired-callback="__onTurnstileExpired"></div>
  </div>

  <p id="turnstile-status" class="turnstile-status" role="status" aria-live="polite">
    セキュリティ確認を読み込んでいます。数秒お待ちください。
  </p>

  <div class="form-group">
    <button type="submit" class="cta-button" disabled>送信する</button>
  </div>
</form>
<div id="form-success-message" class="form-response-message" role="status" aria-live="polite"></div>
<div id="form-error-message" class="form-response-message" role="alert"></div>

<script>
  // Turnstile 準備タイムアウト用タイマー
  let __turnstileTimerId: ReturnType<typeof setTimeout> | undefined;

  function startTurnstileTimer() {
    if (__turnstileTimerId !== undefined) {
      clearTimeout(__turnstileTimerId);
    }
    __turnstileTimerId = setTimeout(() => {
      __turnstileTimerId = undefined;
      const btn = document.querySelector('#contact-form button[type="submit"]') as HTMLButtonElement | null;
      if (btn && btn.disabled) {
        const status = document.getElementById('turnstile-status');
        if (status && !status.classList.contains('turnstile-status--error')) {
          status.textContent = 'セキュリティ確認の準備に時間がかかっています。しばらく待つか、ページを再読み込みしてください。';
          status.classList.add('turnstile-status--error');
        }
      }
    }, 15000);
  }

  // Turnstile コールバック（ウィジェット準備完了 / トークン失効で送信ボタン + 案内テキストを制御）
  (window as any).__onTurnstileSuccess = function() {
    if (__turnstileTimerId !== undefined) {
      clearTimeout(__turnstileTimerId);
      __turnstileTimerId = undefined;
    }
    const btn = document.querySelector('#contact-form button[type="submit"]') as HTMLButtonElement | null;
    if (btn) btn.disabled = false;
    const status = document.getElementById('turnstile-status');
    if (status) status.textContent = '';
  };
  (window as any).__onTurnstileExpired = function() {
    const btn = document.querySelector('#contact-form button[type="submit"]') as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    const status = document.getElementById('turnstile-status');
    if (status) {
      status.textContent = 'セキュリティ確認を読み込んでいます。数秒お待ちください。';
      status.classList.remove('turnstile-status--error');
    }
    startTurnstileTimer();
  };

  // Turnstile 遅延読み込み（IO 非対応 or contact セクション不在時は即時ロード）
  (function loadTurnstileLazy() {
    function loadScript() {
      const script = document.createElement('script');
      script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      script.async = true;
      script.onerror = function() {
        const status = document.getElementById('turnstile-status');
        if (status) {
          status.textContent = 'セキュリティ確認の読み込みに失敗しました。ページを再読み込みしてお試しください。';
          status.classList.add('turnstile-status--error');
        }
      };
      document.head.appendChild(script);
      startTurnstileTimer();
    }

    const contactSection = document.getElementById('contact');
    if (!contactSection || typeof IntersectionObserver === 'undefined') {
      loadScript();
      return;
    }

    let loaded = false;
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting && !loaded) {
          loaded = true;
          loadScript();
          observer.disconnect();
        }
      }
    }, { rootMargin: '500px 0px' });
    observer.observe(contactSection);
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
    const inquiryTypeSelect = document.getElementById('inquiry-type') as HTMLSelectElement | null;
    const otherDetailsGroup = document.getElementById('other-inquiry-details-group');
    const otherDetailsTextarea = document.getElementById('other-inquiry-details') as HTMLTextAreaElement | null;
    const charCountElement = document.getElementById('char-count');
    const leadSourceSelect = document.getElementById('lead-source') as HTMLSelectElement | null;
    const leadSourceOtherGroup = document.getElementById('lead-source-other-group');
    const leadSourceOtherTextarea = document.getElementById('lead-source-other-details') as HTMLTextAreaElement | null;
    const leadSourceCharCount = document.getElementById('lead-source-char-count');
    const formSuccessMessage = document.getElementById('form-success-message');
    const formErrorMessage = document.getElementById('form-error-message');

    function showSuccess(message: string) {
      if (formErrorMessage) formErrorMessage.textContent = '';
      if (formSuccessMessage) {
        formSuccessMessage.textContent = message;
        formSuccessMessage.style.color = 'green';
      } else {
        alert(message);
      }
    }

    function showError(message: string) {
      if (formSuccessMessage) formSuccessMessage.textContent = '';
      if (formErrorMessage) {
        formErrorMessage.textContent = message;
        formErrorMessage.style.color = 'red';
      } else {
        alert(message);
      }
    }

    function clearMessages() {
      if (formSuccessMessage) formSuccessMessage.textContent = '';
      if (formErrorMessage) formErrorMessage.textContent = '';
    }

    if (inquiryTypeSelect && otherDetailsGroup && otherDetailsTextarea && charCountElement) {
      const maxLength = otherDetailsTextarea.maxLength;
      charCountElement.textContent = `${otherDetailsTextarea.value.length} / ${maxLength}`;

      inquiryTypeSelect.addEventListener('change', () => {
        if (inquiryTypeSelect.value === 'other') {
          otherDetailsGroup.classList.remove('hidden');
          otherDetailsTextarea.required = true;
        } else {
          otherDetailsGroup.classList.add('hidden');
          otherDetailsTextarea.required = false;
          otherDetailsTextarea.value = '';
          charCountElement.textContent = `0 / ${maxLength}`;
        }
      });

      otherDetailsTextarea.addEventListener('input', () => {
        charCountElement.textContent = `${otherDetailsTextarea.value.length} / ${maxLength}`;
      });
    }

    if (leadSourceSelect && leadSourceOtherGroup && leadSourceOtherTextarea && leadSourceCharCount) {
      const leadSourceMaxLength = leadSourceOtherTextarea.maxLength;
      leadSourceCharCount.textContent = `${leadSourceOtherTextarea.value.length} / ${leadSourceMaxLength}`;

      leadSourceSelect.addEventListener('change', () => {
        if (leadSourceSelect.value === 'other') {
          leadSourceOtherGroup.classList.remove('hidden');
        } else {
          leadSourceOtherGroup.classList.add('hidden');
          leadSourceOtherTextarea.value = '';
          leadSourceCharCount.textContent = `0 / ${leadSourceMaxLength}`;
        }
      });

      leadSourceOtherTextarea.addEventListener('input', () => {
        leadSourceCharCount.textContent = `${leadSourceOtherTextarea.value.length} / ${leadSourceMaxLength}`;
      });
    }

    if (contactForm) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitButton = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const turnstileInput = contactForm.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
        const turnstileToken = turnstileInput ? turnstileInput.value : '';
        if (!turnstileToken) {
          showError('エラー: セキュリティ検証が完了していません。しばらく待ってから再度お試しください。');
          return;
        }

        submitButton.disabled = true;
        submitButton.textContent = '送信中...';
        clearMessages();

        try {
          const formData = new FormData(contactForm);
          const params = new URLSearchParams();
          for (const [key, value] of formData.entries()) {
            if (key !== 'website_url') {
              params.append(key, value as string);
            }
          }
          if (!params.has('person-in-charge')) {
            const personInCharge = (document.getElementById('person-in-charge') as HTMLInputElement)?.value || '';
            params.append('person-in-charge', personInCharge);
          }

          const functionUrl = contactForm.dataset.functionUrl!;
          const response = await fetch(functionUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString(),
          });

          const responseBodyText = await response.text();

          if (!response.ok) {
            let errorMsg = `HTTP error! status: ${response.status}`;
            try {
              const errData = JSON.parse(responseBodyText);
              errorMsg = errData.error || errorMsg;
            } catch {}
            throw new Error(errorMsg);
          }

          const data = JSON.parse(responseBodyText);

          if (data.success) {
            if (typeof gtag === 'function') {
              const inquiryTypeValue = inquiryTypeSelect?.value || 'unknown';
              const leadSourceValue = leadSourceSelect?.value || '';
              gtag('event', 'contact_form_submit', {
                event_category: 'contact',
                event_label: inquiryTypeValue,
                ...(leadSourceValue && { lead_source: leadSourceValue }),
              });
            }
            showSuccess('お問い合わせありがとうございます。送信完了しました。');
            contactForm.reset();
            if (otherDetailsGroup && otherDetailsTextarea && charCountElement) {
              otherDetailsGroup.classList.add('hidden');
              otherDetailsTextarea.required = false;
              otherDetailsTextarea.value = '';
              charCountElement.textContent = `0 / ${otherDetailsTextarea.maxLength}`;
            }
            if (leadSourceOtherGroup && leadSourceOtherTextarea && leadSourceCharCount) {
              leadSourceOtherGroup.classList.add('hidden');
              leadSourceOtherTextarea.value = '';
              leadSourceCharCount.textContent = `0 / ${leadSourceOtherTextarea.maxLength}`;
            }
          } else {
            throw new Error(data.error || '送信に失敗しました。');
          }
        } catch (error: any) {
          console.error('Form submission error:', error);
          showError('送信中にエラーが発生しました。' + (error.message || ''));
        } finally {
          const turnstileWidget = contactForm.querySelector('.cf-turnstile');
          if (turnstileWidget && typeof turnstile !== 'undefined') {
            turnstile.reset(turnstileWidget);
          }
          submitButton.disabled = true;
          submitButton.textContent = '送信する';
          const statusEl = document.getElementById('turnstile-status');
          if (statusEl) {
            statusEl.textContent = 'セキュリティ確認を読み込んでいます。数秒お待ちください。';
            statusEl.classList.remove('turnstile-status--error');
          }
          startTurnstileTimer();
        }
      });
    }
  });

  declare const turnstile: any;
  declare function gtag(...args: any[]): void;
</script>
