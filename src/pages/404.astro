---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
---
<BaseLayout
  title="ページが見つかりません | いつでもケーキ"
  description="お探しのページは見つかりませんでした。"
  noIndex={true}
>
  <Header slot="header" simple={true} />

  <main class="not-found">
    <div class="container">
      <div class="not-found__content">
        <h1 class="not-found__code">404</h1>
        <h2 class="not-found__title">ページが見つかりません</h2>
        <p class="not-found__message">お探しのページは移動または削除された可能性があります。<br />URLをご確認のうえ、もう一度お試しください。</p>
        <a href="/" class="cta-button">トップページへ戻る</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    padding: 80px 0;
    text-align: center;
    min-height: 50vh;
    display: flex;
    align-items: center;
  }

  .not-found__content {
    max-width: 500px;
    margin: 0 auto;
  }

  .not-found__code {
    font-size: 6rem;
    color: var(--main-color);
    margin-bottom: 0;
    line-height: 1;
  }

  .not-found__title {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
  }

  .not-found__title:after {
    display: none;
  }

  .not-found__message {
    margin-bottom: 2rem;
    color: var(--text-color);
  }
</style>
