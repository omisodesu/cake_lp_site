---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import ResultsSummary from '../components/sections/ResultsSummary.astro';
import Problems from '../components/sections/Problems.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Service from '../components/sections/Service.astro';
import Features from '../components/sections/Features.astro';
import Market from '../components/sections/Market.astro';
import Pricing from '../components/sections/Pricing.astro';
import Process from '../components/sections/Process.astro';
import FAQ from '../components/sections/FAQ.astro';
import TrustSignals from '../components/sections/TrustSignals.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { SITE } from '../data/site';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "いつでもケーキ",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "ケーキ店専門の予約管理システム。サイズ・オプション選択、在庫管理、24時間WEB予約受付に対応。初期費用0円・月額固定費0円、注文代金の5.5%（税込）の従量課金制。"
};
---
<BaseLayout
  title={SITE.title}
  description={SITE.description}
  ogTitle={SITE.ogTitle}
  ogDescription={SITE.ogDescription}
  structuredData={structuredData}
>
  <Header slot="header">
    <div class="header__content">
      <h1 class="header__title">ケーキ店の電話予約、<br>もう手が止まらなくていい。</h1>
      <p class="header__subtitle">ケーキ店専門の予約管理システムで、売上も時間も取り戻す。</p>
      <ul class="header__badges">
        <li>ケーキ店専門</li>
        <li>24時間WEB予約受付</li>
        <li>サイズ・オプション対応</li>
        <li>在庫管理</li>
        <li>初期費用0円・固定費なし</li>
      </ul>
      <div class="header__cta-group">
        <a href="#contact" class="cta-button" data-cta-location="hero" data-cta-type="consultation">まずは無料で相談する</a>
        <a href="#contact" class="cta-button cta-button--secondary" data-cta-location="hero" data-cta-type="inquiry">資料請求・お問い合わせ</a>
      </div>
    </div>
  </Header>

  <main>
    <ResultsSummary />
    <Problems />
    <Testimonials />

    <section class="section section--cta-mid">
      <div class="container cta-mid__inner">
        <p class="cta-mid__text">導入のご相談・資料請求はお気軽にどうぞ</p>
        <a href="#contact" class="cta-button" data-cta-location="mid_page" data-cta-type="consultation">無料相談はこちら</a>
      </div>
    </section>

    <Service />
    <Features />
    <Market />
    <Pricing />
    <Process />
    <FAQ />
    <TrustSignals />

    <section class="section cta" id="contact">
      <div class="container">
        <h2 class="cta__title">初期費用無料で始めよう！<br>まずはお気軽にお問い合わせください</h2>
        <p class="cta__description">ケーキ店の売上アップと業務効率化を実現する「いつでもケーキ」。まずは無料相談・資料請求からお気軽にどうぞ。</p>
        <ContactForm showPersonInCharge={true} />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .header__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .header__title {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: var(--heading-color);
  }

  .header__subtitle {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .header__badges {
    display: flex;
    justify-content: center;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .header__badges li {
    background-color: var(--accent-color);
    color: var(--white);
    padding: 0.5rem 1.2rem;
    border-radius: 2rem;
    font-weight: bold;
    font-size: 1rem;
  }

  .header__cta-group {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section--cta-mid {
    background-color: var(--main-color);
    padding: 40px 0;
  }

  .cta-mid__inner {
    text-align: center;
  }

  .cta-mid__text {
    color: var(--white);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    font-weight: bold;
  }

  .cta {
    background-color: var(--main-color);
    text-align: center;
    padding: 80px 0;
  }

  .cta__title {
    font-size: 2rem;
    margin-bottom: 20px;
  }

  .cta__description {
    max-width: 600px;
    margin: 0 auto 30px;
  }

  @media (max-width: 768px) {
    .header__title {
      font-size: 2.2rem;
    }

    .header__subtitle {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 480px) {
    .header__title {
      font-size: 1.8rem;
    }

    .header__subtitle {
      font-size: 1rem;
    }

    .header__badges li {
      font-size: 0.9rem;
      padding: 0.4rem 1rem;
    }
  }
</style>
