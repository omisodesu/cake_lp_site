---
import GoogleAnalytics from '../components/common/GoogleAnalytics.astro';
import Footer from '../components/common/Footer.astro';
import { SITE } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  noIndex?: boolean;
  structuredData?: object | object[];
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = `${SITE.url}/assets/images/logo_ogp.jpg`,
  ogUrl,
  noIndex = false,
  structuredData,
} = Astro.props;

const canonicalUrl = ogUrl || new URL(Astro.url.pathname, SITE.url).toString();

// JSON-LD は複数渡せるよう配列に正規化する（単一オブジェクトの既存呼び出しも互換）
const structuredDataList = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];

// script 終了タグ等によるエスケープ崩れを防ぐため "<" を Unicode エスケープして出力する
const toJsonLd = (data: object) => JSON.stringify(data).replace(/</g, '\\u003c');
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="llms-txt" content="/llms.txt">
  {noIndex && <meta name="robots" content="noindex">}

  <!-- OGP -->
  <meta property="og:title" content={ogTitle || title}>
  <meta property="og:description" content={ogDescription || description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:image" content={ogImage}>

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalUrl}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.png" type="image/png">

  <!-- GA4(gtag.js)読み込み用の事前接続（モバイル実環境での接続確立を短縮。表示内容には影響しない） -->
  <link rel="preconnect" href="https://www.googletagmanager.com">

  {structuredDataList.map((data) => (
    <script type="application/ld+json" set:html={toJsonLd(data)} />
  ))}

  <GoogleAnalytics />

  <slot name="head" />
</head>
<body>
  <slot name="header" />
  <slot />
  <Footer />
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`}></script>
  <script src="../scripts/ga4-events.ts"></script>
  <slot name="scripts" />
</body>
</html>
